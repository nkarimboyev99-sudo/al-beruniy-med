# MongoDB connection (MongoDB Atlas)
# Get your connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/lab-registr?retryWrites=true&w=majority

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-here

# Server port
PORT=5000

# Node environment
NODE_ENV=production
